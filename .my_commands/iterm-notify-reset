#!/bin/zsh
# iterm-notify-reset — Manual reset: restore original Pokemon background
# Normally the focus watcher handles reset automatically.

local MARKER="/tmp/.iterm-notify-active"
[[ ! -f "$MARKER" ]] && return 0

local orig_image target_tty
orig_image=$(sed -n '1p' "$MARKER")
target_tty=$(sed -n '2p' "$MARKER")
rm -f "$MARKER" /tmp/.iterm-notify-watcher-pid

[[ -z "$orig_image" || -z "$target_tty" ]] && return 0

osascript -e "
tell application \"iTerm2\"
  repeat with w in windows
    repeat with t in tabs of w
      repeat with s in sessions of t
        if tty of s is \"$target_tty\" then
          set background image of s to \"$orig_image\"
          return
        end if
      end repeat
    end repeat
  end repeat
end tell" 2>/dev/null

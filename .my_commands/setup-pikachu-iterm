#!/bin/zsh
# iTerm2 に Pikachu プロファイルをセットアップする
# Usage: setup-pikachu-iterm
#
# 1. DynamicProfile をコピー
# 2. ピカチュウ画像のパスをプロファイルに書き込み
# 3. iTerm2 を再読み込み

set -euo pipefail

DOTPATH="$HOME/my_dotfiles"
PROFILE_SRC="$DOTPATH/iterm2/PikachuProfile.json"
PROFILE_DST="$HOME/Library/Application Support/iTerm2/DynamicProfiles/PikachuProfile.json"
PIKACHU_IMG=""

# ── ピカチュウ画像を探す ─────────────────────────────────
find_pikachu() {
  local candidates=(
    "$HOME/.local/lib/python3.11/site-packages/pokemonterminal/Images/Generation I - Kanto/025.jpg"
    "$HOME/.local/lib/python3.12/site-packages/pokemonterminal/Images/Generation I - Kanto/025.jpg"
    "$HOME/.local/lib/python3.13/site-packages/pokemonterminal/Images/Generation I - Kanto/025.jpg"
  )
  for path in "${candidates[@]}"; do
    if [[ -f "$path" ]]; then
      PIKACHU_IMG="$path"
      return 0
    fi
  done

  # pip show で探す
  local pkg_dir
  pkg_dir=$(python3 -c "import pokemonterminal; import os; print(os.path.dirname(pokemonterminal.__file__))" 2>/dev/null || true)
  if [[ -n "$pkg_dir" && -f "$pkg_dir/Images/Generation I - Kanto/025.jpg" ]]; then
    PIKACHU_IMG="$pkg_dir/Images/Generation I - Kanto/025.jpg"
    return 0
  fi

  echo "Error: ピカチュウ画像が見つかりません。pokemon-terminal をインストールしてください。"
  echo "  pip3 install --user git+https://github.com/LazoCoder/Pokemon-Terminal.git"
  return 1
}

# ── メイン ────────────────────────────────────────────────
find_pikachu

echo "Pikachu image: $PIKACHU_IMG"

# プロファイルJSONにピカチュウ画像パスを埋め込んでコピー
mkdir -p "$(dirname "$PROFILE_DST")"

# sed でパスを挿入 (JSON内の空文字列を実パスに置換)
sed "s|\"Background Image Location\": \"\"|\"Background Image Location\": \"$PIKACHU_IMG\"|" \
  "$PROFILE_SRC" > "$PROFILE_DST"

echo "✅ iTerm2 Dynamic Profile をインストールしました"
echo ""
echo "次のステップ:"
echo "  1. iTerm2 > Settings > Profiles で 'Pikachu' プロファイルを選択"
echo "  2. Other Actions... > Set as Default"
echo "  3. 新しいタブを開いて確認"

#!/bin/zsh
# iterm-notify-glow — iTerm2 gradual pulse notification + persistent tint
# Usage: iterm-notify-glow [<display_time>] [<exit_code>] [<command_text>] [<tty>]
#
# iTerm2 constraint: ANY session property change (color, name, OSC escape)
# clears the session-level background image. Therefore ONLY these are safe:
#   - set background image (the image itself)
#   - display notification (system-level, not session)
#
# Notification flow:
#   1. Gradual pulse animation × 3 cycles (dark ↔ light)
#   2. Settle on blue-tinted (success) or red-tinted (error) background
#   3. Tinted background persists until session regains focus (auto-reset)
#   4. Focus watcher: tracks "defocus → refocus" transition to avoid
#      premature reset when user is already looking at the session

local display_time="${1:-}"
local exit_code="${2:-0}"
local cmd_text="${3:-}"
local my_tty="${4:-}"
local CACHE_DIR="$HOME/.cache/poke-notify"
local MARKER="/tmp/.iterm-notify-active"
local osa_tell='tell application "iTerm2" to tell current session of current tab of current window to'

# ── 1. Get current background image ─────────────────────
local orig_image
orig_image=$(osascript -e "$osa_tell return background image" 2>/dev/null)

if [[ -z "$orig_image" || "$orig_image" == "missing value" ]]; then
  return 0
fi

# If notification is already active, use the stored original
if [[ -f "$MARKER" ]]; then
  local stored_orig
  stored_orig=$(head -1 "$MARKER")
  [[ -n "$stored_orig" && -f "$stored_orig" ]] && orig_image="$stored_orig"
fi

# ── 2. Determine tint color ─────────────────────────────
local tint_color="blue"
(( exit_code != 0 )) && tint_color="red"

# ── 3. Generate image variants (cached) ─────────────────
mkdir -p "$CACHE_DIR"
local img_hash
img_hash=$(md5 -q "$orig_image" 2>/dev/null)
[[ -z "$img_hash" ]] && return 0

local prefix="$CACHE_DIR/${img_hash}"

if [[ ! -f "${prefix}_blue.png" || ! -f "${prefix}_b1.png" ]]; then
  python3 -c "
from PIL import Image, ImageEnhance

img = Image.open('${orig_image}').convert('RGB')
w, h = img.size

# Brightness steps — bright enough to see Pokemon silhouette at darkest
for idx, brt in [(1, 0.20), (2, 0.30), (3, 0.42), (4, 0.58)]:
    ImageEnhance.Brightness(img).enhance(brt).save('${prefix}_b%d.png' % idx, 'PNG')

# Blue-tinted settle — pastel sky blue
dark = ImageEnhance.Brightness(img).enhance(0.30)
blue = Image.new('RGB', (w, h), (170, 215, 255))
Image.blend(dark, blue, 0.40).save('${prefix}_blue.png', 'PNG')

# Red-tinted settle — pastel salmon pink
red = Image.new('RGB', (w, h), (255, 160, 160))
Image.blend(dark, red, 0.40).save('${prefix}_red.png', 'PNG')
" 2>/dev/null || return 0
fi

# ── 4. Gradual pulse animation × 2 cycles ───────────────
_set_bg() { osascript -e "$osa_tell set background image to \"$1\"" 2>/dev/null }

local cycle
for cycle in 1 2; do
  # Darken: bright → dim
  _set_bg "${prefix}_b3.png";  sleep 0.12
  _set_bg "${prefix}_b2.png";  sleep 0.12
  _set_bg "${prefix}_b1.png";  sleep 0.15
  # Brighten: dim → bright
  _set_bg "${prefix}_b2.png";  sleep 0.12
  _set_bg "${prefix}_b3.png";  sleep 0.12
  _set_bg "${prefix}_b4.png";  sleep 0.15
done

# Settle on tinted background
_set_bg "${prefix}_b3.png";  sleep 0.10
_set_bg "${prefix}_${tint_color}.png"

# ── 5. Write marker for persistent state ────────────────
echo "${orig_image}" > "$MARKER"
echo "${tint_color}" >> "$MARKER"

# ── 6. Focus watcher (defocus → refocus transition) ─────
# Tracks state: must see "not focused" THEN "focused" before resetting.
# Prevents premature reset when user is already looking at the session.
(
  # $TTY env var works in subshells; $(tty) does not
  [[ -z "$my_tty" ]] && my_tty="$TTY"
  [[ -z "$my_tty" || "$my_tty" == "not a tty" ]] && exit 0

  local state="init"
  local focused_tty

  while [[ -f "$MARKER" ]]; do
    focused_tty=$(osascript -e 'tell application "iTerm2" to return tty of current session of current tab of current window' 2>/dev/null)

    case "$state" in
      init)
        if [[ "$focused_tty" == "$my_tty" ]]; then
          # Currently focused — wait for user to leave first
          state="wait_defocus"
        else
          # Already away — wait for user to return
          state="wait_refocus"
        fi
        ;;
      wait_defocus)
        if [[ "$focused_tty" != "$my_tty" ]]; then
          state="wait_refocus"
        fi
        ;;
      wait_refocus)
        if [[ "$focused_tty" == "$my_tty" ]]; then
          # User returned — trigger reset
          sleep 0.3
          local reset_script="$HOME/.my_commands/iterm-notify-reset"
          [[ -f "$reset_script" ]] && zsh "$reset_script"
          exit 0
        fi
        ;;
    esac

    sleep 1.5
  done
) &!

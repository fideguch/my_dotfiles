#!/bin/zsh
# iterm-notify-glow — iTerm2 gradual pulse notification + persistent tint
# Usage: iterm-notify-glow [<display_time>] [<exit_code>] [<command_text>] [<tty>]
#
# iTerm2 constraints:
#   - ONLY 'set background image' is safe (OSC/tab color/badge clear bg)
#   - Profile Blend=0.40 darkens everything: effective = pixel * 0.60
#   - All brightness values are pre-compensated for the 40% blend
#
# All osascript calls target the session by TTY path (not current focus)
# so split-pane operations never affect the wrong pane.

local display_time="${1:-}"
local exit_code="${2:-0}"
local cmd_text="${3:-}"
local my_tty="${4:-$TTY}"
local CACHE_DIR="$HOME/.cache/poke-notify"
local MARKER="/tmp/.iterm-notify-active"

[[ -z "$my_tty" || "$my_tty" == "not a tty" ]] && return 0

# ── AppleScript helpers: target by TTY ───────────────────
_osa_get_bg() {
  osascript -e "
tell application \"iTerm2\"
  repeat with w in windows
    repeat with t in tabs of w
      repeat with s in sessions of t
        if tty of s is \"$my_tty\" then return background image of s
      end repeat
    end repeat
  end repeat
end tell" 2>/dev/null
}

_osa_set_bg() {
  osascript -e "
tell application \"iTerm2\"
  repeat with w in windows
    repeat with t in tabs of w
      repeat with s in sessions of t
        if tty of s is \"$my_tty\" then
          set background image of s to \"$1\"
          return
        end if
      end repeat
    end repeat
  end repeat
end tell" 2>/dev/null
}

# ── 1. Get current background image ─────────────────────
local orig_image
orig_image=$(_osa_get_bg)

if [[ -z "$orig_image" || "$orig_image" == "missing value" ]]; then
  return 0
fi

# If notification is already active, use the stored original
if [[ -f "$MARKER" ]]; then
  local stored_orig
  stored_orig=$(sed -n '1p' "$MARKER")
  [[ -n "$stored_orig" && -f "$stored_orig" ]] && orig_image="$stored_orig"
fi

# ── 2. Determine tint color ─────────────────────────────
local tint_color="blue"
(( exit_code != 0 )) && tint_color="red"

# ── 3. Generate image variants (cached) ─────────────────
# Brightness values compensated for iTerm2 Blend=0.40:
#   effective_brightness = value × 0.60
#   b1: 0.35 → user sees 0.21 (dim but pokemon visible)
#   b2: 0.50 → user sees 0.30
#   b3: 0.70 → user sees 0.42
#   b4: 0.90 → user sees 0.54
#   tint base: 0.50 → user sees 0.30
mkdir -p "$CACHE_DIR"
local img_hash
img_hash=$(md5 -q "$orig_image" 2>/dev/null)
[[ -z "$img_hash" ]] && return 0

local prefix="$CACHE_DIR/${img_hash}"

if [[ ! -f "${prefix}_blue.png" || ! -f "${prefix}_b1.png" ]]; then
  python3 -c "
from PIL import Image, ImageEnhance

img = Image.open('${orig_image}').convert('RGB')
w, h = img.size

# Pre-compensated for Blend=0.40 (effective = value * 0.60)
for idx, brt in [(1, 0.35), (2, 0.50), (3, 0.70), (4, 0.90)]:
    ImageEnhance.Brightness(img).enhance(brt).save('${prefix}_b%d.png' % idx, 'PNG')

# Tinted variants — pastel, high visibility after 40% darkening
dark = ImageEnhance.Brightness(img).enhance(0.50)
blue = Image.new('RGB', (w, h), (170, 215, 255))
Image.blend(dark, blue, 0.45).save('${prefix}_blue.png', 'PNG')

red = Image.new('RGB', (w, h), (255, 160, 160))
Image.blend(dark, red, 0.45).save('${prefix}_red.png', 'PNG')
" 2>/dev/null || return 0
fi

# ── 4. Gradual pulse animation × 2 cycles ───────────────
local cycle
for cycle in 1 2; do
  _osa_set_bg "${prefix}_b3.png";  sleep 0.12
  _osa_set_bg "${prefix}_b2.png";  sleep 0.12
  _osa_set_bg "${prefix}_b1.png";  sleep 0.15
  _osa_set_bg "${prefix}_b2.png";  sleep 0.12
  _osa_set_bg "${prefix}_b3.png";  sleep 0.12
  _osa_set_bg "${prefix}_b4.png";  sleep 0.15
done

# Settle on tinted background
_osa_set_bg "${prefix}_b3.png";  sleep 0.10
_osa_set_bg "${prefix}_${tint_color}.png"

# ── 5. Write marker ─────────────────────────────────────
echo "${orig_image}" > "$MARKER"
echo "${tint_color}" >> "$MARKER"
echo "${my_tty}" >> "$MARKER"

# ── 6. Focus watcher (defocus → refocus) ────────────────
(
  local state="init"
  local focused_tty
  local target_tty="$my_tty"
  local orig="$orig_image"
  local pfx="$prefix"

  while [[ -f "$MARKER" ]]; do
    focused_tty=$(osascript -e 'tell application "iTerm2" to return tty of current session of current tab of current window' 2>/dev/null)

    case "$state" in
      init)
        if [[ "$focused_tty" == "$target_tty" ]]; then
          state="wait_defocus"
        else
          state="wait_refocus"
        fi
        ;;
      wait_defocus)
        [[ "$focused_tty" != "$target_tty" ]] && state="wait_refocus"
        ;;
      wait_refocus)
        if [[ "$focused_tty" == "$target_tty" ]]; then
          # User returned — reset directly (no external script dependency)
          rm -f "$MARKER"
          # Instant restore
          osascript -e "
tell application \"iTerm2\"
  repeat with w in windows
    repeat with t in tabs of w
      repeat with s in sessions of t
        if tty of s is \"$target_tty\" then
          set background image of s to \"$orig\"
          return
        end if
      end repeat
    end repeat
  end repeat
end tell" 2>/dev/null
          exit 0
        fi
        ;;
    esac

    sleep 1.5
  done
) &!

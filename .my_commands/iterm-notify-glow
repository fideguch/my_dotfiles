#!/bin/zsh
# iterm-notify-glow — iTerm2 notification via Pokemon background swap
# Usage: iterm-notify-glow [<display_time>] [<exit_code>] [<command_text>] [<tty>]
#
# Notification = swap through ~15 random Pokemon, then hold the last one.
# On session return, restore the original Pokemon instantly.
# No brightness/tint/blend manipulation — only image path swaps.

local display_time="${1:-}"
local exit_code="${2:-0}"
local cmd_text="${3:-}"
local my_tty="${4:-$TTY}"
local MARKER="/tmp/.iterm-notify-active"
local WATCHER_PID_FILE="/tmp/.iterm-notify-watcher-pid"
local POKE_DIR="$HOME/.local/lib/python3.11/site-packages/pokemonterminal/Images"

[[ -z "$my_tty" || "$my_tty" == "not a tty" ]] && return 0

# ── Kill any existing watcher ────────────────────────────
if [[ -f "$WATCHER_PID_FILE" ]]; then
  kill "$(cat "$WATCHER_PID_FILE" 2>/dev/null)" 2>/dev/null
  rm -f "$WATCHER_PID_FILE"
fi
rm -f "$MARKER"

# ── AppleScript helpers ──────────────────────────────────
_osa_set_bg() {
  osascript -e "
tell application \"iTerm2\"
  repeat with w in windows
    repeat with t in tabs of w
      repeat with s in sessions of t
        if tty of s is \"$my_tty\" then
          set background image of s to \"$1\"
          return
        end if
      end repeat
    end repeat
  end repeat
end tell" 2>/dev/null
}

_is_focused() {
  local f
  f=$(osascript -e 'tell application "iTerm2" to return tty of current session of current tab of current window' 2>/dev/null)
  [[ "$f" == "$my_tty" ]]
}

# ── 1. Get current background image ─────────────────────
local orig_image
orig_image=$(osascript -e "
tell application \"iTerm2\"
  repeat with w in windows
    repeat with t in tabs of w
      repeat with s in sessions of t
        if tty of s is \"$my_tty\" then return background image of s
      end repeat
    end repeat
  end repeat
end tell" 2>/dev/null)

[[ -z "$orig_image" || "$orig_image" == "missing value" ]] && return 0

# ── 2. Pick 15 random Pokemon (excluding current) ───────
local -a swap_pool
swap_pool=( $(find "$POKE_DIR" -name "*.jpg" 2>/dev/null | grep -v "$(basename "$orig_image")" | sort -R | head -15) )
(( ${#swap_pool[@]} == 0 )) && return 0

# ── 3. Swap animation (focus-aware) ─────────────────────
local aborted=0
for img in "${swap_pool[@]}"; do
  if _is_focused; then
    _osa_set_bg "$orig_image"
    aborted=1
    break
  fi
  _osa_set_bg "$img"
  sleep 0.3
done

(( aborted )) && return 0

# ── 4. macOS notification (supplementary) ────────────────
local notify_title="${cmd_text:-Command}"
(( exit_code != 0 )) && notify_title="FAILED: ${notify_title}"
local notify_body=""
[[ -n "$display_time" ]] && notify_body="Elapsed: ${display_time}"
osascript -e "display notification \"${notify_body}\" with title \"iTerm2\" subtitle \"${notify_title}\" sound name \"Glass\"" 2>/dev/null

# ── 5. Write marker + start watcher ─────────────────────
echo "${orig_image}" > "$MARKER"
echo "${my_tty}" >> "$MARKER"

(
  echo $$ > "$WATCHER_PID_FILE"
  local state="init" focused_tty
  local target_tty="$my_tty" orig="$orig_image"

  while [[ -f "$MARKER" ]]; do
    focused_tty=$(osascript -e 'tell application "iTerm2" to return tty of current session of current tab of current window' 2>/dev/null)

    case "$state" in
      init)
        [[ "$focused_tty" == "$target_tty" ]] && state="wait_defocus" || state="wait_refocus"
        ;;
      wait_defocus)
        [[ "$focused_tty" != "$target_tty" ]] && state="wait_refocus"
        ;;
      wait_refocus)
        if [[ "$focused_tty" == "$target_tty" ]]; then
          rm -f "$MARKER" "$WATCHER_PID_FILE"
          osascript -e "
tell application \"iTerm2\"
  repeat with w in windows
    repeat with t in tabs of w
      repeat with s in sessions of t
        if tty of s is \"$target_tty\" then
          set background image of s to \"$orig\"
          return
        end if
      end repeat
    end repeat
  end repeat
end tell" 2>/dev/null
          exit 0
        fi
        ;;
    esac
    sleep 1.5
  done
  rm -f "$WATCHER_PID_FILE"
) &!

#!/usr/bin/env python3
"""ポケモン逆引き検索。名前(日本語/英語)、タイプ、地方、種族値で検索。
Usage:
  pokefind ミュウツー          # 日本語名で検索
  pokefind gengar             # 英語名で検索
  pokefind mewtwo             # 部分一致OK
  pokefind -t ghost           # タイプで絞込
  pokefind -r kanto           # 地方で絞込
  pokefind -s 500             # 合計種族値500以上
  pokefind ゲンガー -s 400     # 名前+種族値の組合せ
"""
import argparse
import sys

from pokemonterminal.database import Database
from pokeutil import (
    load_data, fmt_type, fmt_region, get_ja_name, fmt_stats, get_stats,
)


def main():
    parser = argparse.ArgumentParser(description="ポケモン逆引き検索")
    parser.add_argument("query", nargs="?", default="",
                        help="名前で検索 (日本語/英語, 部分一致)")
    parser.add_argument("-t", "--type", nargs="+", dest="types",
                        help="タイプで絞込")
    parser.add_argument("-r", "--region", help="地方で絞込")
    parser.add_argument("-s", "--stats", type=int,
                        help="合計種族値がこの値以上")
    args = parser.parse_args()

    if not args.query and not args.types and not args.region and not args.stats:
        parser.print_help()
        sys.exit(1)

    db = Database()
    pokemon_list = db.get_all()
    data = load_data()

    # 名前フィルタ (日本語/英語 部分一致)
    if args.query:
        query = args.query.lower()
        pokemon_list = [
            p for p in pokemon_list
            if query in p.get_name().lower()
            or query in get_ja_name(data, p.get_name()).lower()
        ]

    # タイプフィルタ
    if args.types:
        types = {t.lower() for t in args.types}
        pokemon_list = [
            p for p in pokemon_list
            if p.get_pkmn_type().lower() in types
            or (p.get_pkmn_type_secondary() or "").lower() in types
        ]

    # 地方フィルタ
    if args.region:
        region = args.region.lower()
        pokemon_list = [p for p in pokemon_list if p.get_region().lower() == region]

    # 種族値フィルタ
    if args.stats:
        min_total = args.stats
        pokemon_list = [
            p for p in pokemon_list
            if sum(get_stats(data, p.get_name()) or [0]) >= min_total
        ]

    if not pokemon_list:
        print("該当するポケモンが見つかりません")
        sys.exit(1)

    # 図鑑番号順にソート
    pokemon_list.sort(key=lambda p: (p.get_id() == "---", p.get_id()))

    # 表示
    header = (
        f"{'ID':>5}  {'名前':<10} {'Name':<16}"
        f"{'地方':<14} {'タイプ':<24} {'種族値'}"
    )
    sep = "-" * 110
    print(header)
    print(sep)
    for p in pokemon_list:
        pid = p.get_id()
        en_name = p.get_name()
        ja_name = get_ja_name(data, en_name)
        region = fmt_region(p.get_region())
        t1 = fmt_type(p.get_pkmn_type())
        t2 = p.get_pkmn_type_secondary()
        types = t1 + (f"/{fmt_type(t2)}" if t2 else "")
        stats = fmt_stats(get_stats(data, en_name))
        print(
            f"{pid:>5}  {ja_name:<10} {en_name:<16}"
            f"{region:<14} {types:<24} {stats}"
        )
    print(sep)
    print(f"{len(pokemon_list)} 匹")


if __name__ == "__main__":
    main()

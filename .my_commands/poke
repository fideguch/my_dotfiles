#!/usr/bin/env python3
"""pokemon コマンドの短縮版 (図鑑情報+種族値を表示+背景設定)
Usage:
  poke 150         # ミュウツー
  poke -n gengar   # ゲンガー
  poke             # ランダム
  poke --clear     # 背景をクリア

Backend:
  iTerm2:       AppleScript via pokemon-terminal
  cmux/Ghostty: Kitty graphics protocol (z=-1, behind text)
                TRAPWINCH in .zshrc handles resize.
"""
import base64
import os
import struct
import subprocess
import sys

from pokemonterminal.database import Database
from pokeutil import load_data, pokemon_oneliner

CURRENT_POKEMON_PATH = os.path.expanduser("~/.cache/poke-current")
FADED_IMAGE_DIR = os.path.expanduser("~/.cache/poke-faded")
BG_OPACITY = 0.15  # how visible the background pokemon is


# ── Pokemon lookup ────────────────────────────────────────

def find_chosen_pokemon(args):
    """dry-run で選ばれるポケモンを特定し、DB上のオブジェクトを返す"""
    result = subprocess.run(
        ["pokemon"] + args + ["-dr"],
        capture_output=True, text=True,
    )
    output = result.stdout + result.stderr
    chosen_name = None
    for line in output.splitlines():
        if "Chose" in line:
            chosen_name = line.split("Chose")[-1].strip()
            break
    if not chosen_name:
        return None
    db = Database()
    for p in db.get_all():
        if p.get_name().lower() == chosen_name.lower():
            return p
    return None


def save_current_pokemon(en_name: str) -> None:
    """Save current Pokemon name for reference."""
    os.makedirs(os.path.dirname(CURRENT_POKEMON_PATH), exist_ok=True)
    with open(CURRENT_POKEMON_PATH, "w") as f:
        f.write(en_name)


# ── iTerm2 backend ────────────────────────────────────────

def set_iterm_background(pid: str, en_name: str) -> None:
    """Set iTerm2 background via pokemon-terminal (AppleScript)."""
    if pid != "---":
        subprocess.run(["pokemon", pid], stdout=subprocess.DEVNULL)
    else:
        subprocess.run(["pokemon", "-n", en_name], stdout=subprocess.DEVNULL)


# ── Kitty graphics protocol backend (cmux/Ghostty) ───────
#
# Renders the image behind text using z=-1.
# The image is scaled by the terminal to fill c columns × r rows.
# Writing to /dev/tty ensures escape sequences reach the terminal
# even when stdout is captured.

def _write_tty(data: str) -> None:
    """Write directly to the controlling terminal."""
    try:
        with open("/dev/tty", "w") as tty:
            tty.write(data)
            tty.flush()
    except OSError:
        sys.stdout.write(data)
        sys.stdout.flush()


def _get_terminal_size_cells() -> tuple[int, int]:
    """Get terminal size in cells (cols, rows)."""
    try:
        size = os.get_terminal_size()
        return (size.columns, size.lines)
    except OSError:
        return (80, 24)


def _get_terminal_size_pixels() -> tuple[int, int]:
    """Get terminal size in pixels via ioctl TIOCGWINSZ."""
    try:
        import fcntl
        import termios
        with open("/dev/tty", "rb") as tty:
            result = fcntl.ioctl(tty.fileno(), termios.TIOCGWINSZ,
                                 b"\x00" * 8)
            rows, cols, xpixel, ypixel = struct.unpack("HHHH", result)
            if xpixel > 0 and ypixel > 0:
                return (xpixel, ypixel)
    except Exception:
        pass
    return (0, 0)


def _kitty_cmd(payload: str, data: str = "") -> str:
    """Build a Kitty graphics protocol escape sequence."""
    if data:
        return f"\033_G{payload};{data}\033\\"
    return f"\033_G{payload}\033\\"


def clear_kitty_images() -> None:
    """Delete all Kitty graphics images from the terminal."""
    _write_tty(_kitty_cmd("a=d,d=A"))


def _prepare_background_image(src: str) -> str:
    """Resize image to terminal pixel dimensions and fade for background use.

    1. Get terminal size in pixels via TIOCGWINSZ
    2. Stretch image to exactly fill terminal (ignore aspect ratio)
    3. Darken to BG_OPACITY for readability
    """
    from PIL import Image, ImageEnhance

    os.makedirs(FADED_IMAGE_DIR, exist_ok=True)
    basename = os.path.splitext(os.path.basename(src))[0] + ".png"
    dst = os.path.join(FADED_IMAGE_DIR, basename)

    px_w, px_h = _get_terminal_size_pixels()
    if px_w == 0 or px_h == 0:
        px_w, px_h = 1920, 1080  # fallback

    try:
        img = Image.open(src).convert("RGB")
        img = img.resize((px_w, px_h), Image.LANCZOS)
        enhancer = ImageEnhance.Brightness(img)
        faded = enhancer.enhance(BG_OPACITY)
        faded.save(dst, "PNG")
        return dst
    except Exception:
        return src


def set_kitty_background(image_path: str) -> None:
    """Display image behind text using Kitty graphics protocol.

    1. Prepare image (resize to terminal pixels + fade)
    2. Delete old images
    3. Move cursor to (1,1), place image with z=-1, restore cursor
    """
    cols, rows = _get_terminal_size_cells()
    prepared = _prepare_background_image(image_path)
    path_b64 = base64.standard_b64encode(
        os.path.abspath(prepared).encode()
    ).decode()

    # Delete all previous Kitty images
    clear_kitty_images()

    # Save cursor, move to origin, place image behind text, restore cursor
    _write_tty(
        "\033[s"            # save cursor
        "\033[1;1H"         # move to top-left
        + _kitty_cmd(f"a=T,t=f,z=-1,c={cols},r={rows}", path_b64)
        + "\033[u"          # restore cursor
    )


def clear_ghostty_background() -> None:
    """Clear background image."""
    clear_kitty_images()
    try:
        os.remove(CURRENT_POKEMON_PATH)
    except FileNotFoundError:
        pass


# ── Main ──────────────────────────────────────────────────

def main():
    args = sys.argv[1:]
    term = os.environ.get("TERM_PROGRAM", "")

    if "--clear" in args:
        if term == "ghostty":
            clear_ghostty_background()
        return

    chosen = find_chosen_pokemon(args)
    if not chosen:
        subprocess.run(["pokemon"] + args)
        return

    pid = chosen.get_id()
    en_name = chosen.get_name()

    if term == "ghostty":
        set_kitty_background(chosen.get_path())
        save_current_pokemon(en_name)
    else:
        set_iterm_background(pid, en_name)

    data = load_data()
    t1 = chosen.get_pkmn_type()
    t2 = chosen.get_pkmn_type_secondary()
    print(pokemon_oneliner(pid, en_name, data, t1, t2))


if __name__ == "__main__":
    main()

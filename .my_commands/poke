#!/usr/bin/env python3
"""Pokemon terminal background + stats one-liner.

Usage:
  poke 150         # Mewtwo (by Pokedex ID)
  poke -n gengar   # Gengar (by name)
  poke             # Random
  poke --clear     # Remove background

Backend:
  iTerm2:       AppleScript via pokemon-terminal
  cmux/Ghostty: config-file + `cmux themes set` reload for instant change
"""
from __future__ import annotations

import fcntl
import os
import struct
import subprocess
import sys
import termios

from pokemonterminal.database import Database
from pokeutil import load_data, pokemon_oneliner

CURRENT_POKEMON_PATH = os.path.expanduser("~/.cache/poke-current")
GHOSTTY_BG_CONFIG = os.path.expanduser("~/.config/ghostty/background")
PREPARED_IMAGE_DIR = os.path.expanduser("~/.cache/poke-bg")
CACHED_SIZE_PATH = os.path.expanduser("~/.cache/poke-surface-size")
BG_BRIGHTNESS = 0.15


# ── Pokemon lookup ────────────────────────────────────────

def find_chosen_pokemon(args: list[str]) -> object | None:
    """Identify the chosen pokemon via dry-run, return DB object."""
    result = subprocess.run(
        ["pokemon", *args, "-dr"],
        capture_output=True,
        text=True,
    )
    output = result.stdout + result.stderr
    chosen_name = None
    for line in output.splitlines():
        if "Chose" in line:
            chosen_name = line.split("Chose")[-1].strip()
            break
    if not chosen_name:
        return None
    db = Database()
    for p in db.get_all():
        if p.get_name().lower() == chosen_name.lower():
            return p
    return None


def save_current_pokemon(en_name: str) -> None:
    """Persist current pokemon name."""
    os.makedirs(os.path.dirname(CURRENT_POKEMON_PATH), exist_ok=True)
    with open(CURRENT_POKEMON_PATH, "w") as f:
        f.write(en_name)


def _read_current_pokemon() -> str | None:
    """Read the currently displayed pokemon name."""
    try:
        with open(CURRENT_POKEMON_PATH) as f:
            return f.read().strip()
    except FileNotFoundError:
        return None


# ── iTerm2 backend ────────────────────────────────────────

def set_iterm_background(pid: str, en_name: str) -> None:
    """Set iTerm2 background via pokemon-terminal (AppleScript)."""
    cmd = ["pokemon", pid] if pid != "---" else ["pokemon", "-n", en_name]
    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


# ── cmux/Ghostty config-file backend ─────────────────────

def _save_surface_size(w: int, h: int) -> None:
    """Cache the last known surface pixel size."""
    try:
        os.makedirs(os.path.dirname(CACHED_SIZE_PATH), exist_ok=True)
        with open(CACHED_SIZE_PATH, "w") as f:
            f.write(f"{w} {h}")
    except OSError:
        pass


def _load_cached_surface_size() -> tuple[int, int]:
    """Load last known surface pixel size from cache."""
    try:
        with open(CACHED_SIZE_PATH) as f:
            parts = f.read().strip().split()
            if len(parts) == 2:
                return (int(parts[0]), int(parts[1]))
    except (FileNotFoundError, ValueError):
        pass
    return (0, 0)


def _get_window_pixel_size() -> tuple[int, int]:
    """Get the cmux front window size for background-image sizing.

    background-image is shared across all panes in a window.
    Uses AppleScript front window (the active window where poke runs).
    Falls back to TIOCGWINSZ then cache.

    Note: background-image is global across all cmux windows.
    When multiple windows have different sizes, the image is
    sized for the front window. This is a Ghostty limitation.
    """
    # Primary: AppleScript front window size
    try:
        result = subprocess.run(
            ["osascript", "-e",
             'tell application "System Events" to tell process "cmux" '
             'to get size of front window'],
            capture_output=True, text=True, timeout=3,
        )
        if result.returncode == 0:
            parts = result.stdout.strip().split(",")
            if len(parts) == 2:
                w = int(parts[0].strip())
                h = int(parts[1].strip())
                if w > 0 and h > 0:
                    _save_surface_size(w, h)
                    return (w, h)
    except (subprocess.TimeoutExpired, OSError, ValueError):
        pass

    # Fallback: TIOCGWINSZ (pane pixels, better than nothing)
    try:
        with open("/dev/tty", "rb") as tty:
            result = fcntl.ioctl(
                tty.fileno(), termios.TIOCGWINSZ, b"\x00" * 8,
            )
            _, _, xpixel, ypixel = struct.unpack("HHHH", result)
            if xpixel > 0 and ypixel > 0:
                _save_surface_size(xpixel, ypixel)
                return (xpixel, ypixel)
    except OSError:
        pass

    # Last resort: cached value
    return _load_cached_surface_size()


def _prepare_background(src: str) -> str:
    """Resize image to window size and darken for readability."""
    try:
        from PIL import Image, ImageEnhance
    except ImportError:
        print("[poke] Pillow required. Run: pip install Pillow",
              file=sys.stderr)
        return src

    px_w, px_h = _get_window_pixel_size()
    if px_w == 0 or px_h == 0:
        return src

    os.makedirs(PREPARED_IMAGE_DIR, exist_ok=True)
    basename = os.path.splitext(os.path.basename(src))[0] + ".png"
    dst = os.path.join(PREPARED_IMAGE_DIR, basename)

    img = Image.open(src).convert("RGB")
    img = img.resize((px_w, px_h), Image.LANCZOS)
    img = ImageEnhance.Brightness(img).enhance(BG_BRIGHTNESS)
    img.save(dst, "PNG")
    return dst


def _get_current_theme() -> str:
    """Read current cmux theme name."""
    try:
        result = subprocess.run(
            ["cmux", "themes", "list"],
            capture_output=True, text=True, timeout=5,
        )
        for line in result.stdout.splitlines():
            if line.startswith("Current dark:"):
                return line.split(":", 1)[1].strip()
    except (subprocess.TimeoutExpired, FileNotFoundError):
        pass
    return "Japanesque"


def _reload_cmux_config() -> None:
    """Trigger cmux config reload via themes set."""
    theme = _get_current_theme()
    subprocess.run(
        ["cmux", "themes", "set", theme],
        capture_output=True, timeout=5,
    )


def set_ghostty_background(image_path: str) -> None:
    """Prepare image, write config, and trigger reload."""
    os.makedirs(os.path.dirname(GHOSTTY_BG_CONFIG), exist_ok=True)
    prepared = _prepare_background(image_path)
    with open(GHOSTTY_BG_CONFIG, "w") as f:
        f.write(f"background-image = {prepared}\n")
    _reload_cmux_config()


def clear_ghostty_background() -> None:
    """Remove background image and reload."""
    with open(GHOSTTY_BG_CONFIG, "w") as f:
        f.write("# no background\n")
    _reload_cmux_config()
    try:
        os.remove(CURRENT_POKEMON_PATH)
    except FileNotFoundError:
        pass


# ── Main ──────────────────────────────────────────────────

def main() -> None:
    args = sys.argv[1:]
    term = os.environ.get("TERM_PROGRAM", "")

    if "--clear" in args:
        if term == "ghostty":
            clear_ghostty_background()
        return

    chosen = find_chosen_pokemon(args)
    if not chosen:
        subprocess.run(["pokemon", *args])
        return

    pid = chosen.get_id()
    en_name = chosen.get_name()

    if term == "ghostty":
        set_ghostty_background(chosen.get_path())
        save_current_pokemon(en_name)
    else:
        set_iterm_background(pid, en_name)

    data = load_data()
    t1 = chosen.get_pkmn_type()
    t2 = chosen.get_pkmn_type_secondary()
    print(pokemon_oneliner(pid, en_name, data, t1, t2))


if __name__ == "__main__":
    main()

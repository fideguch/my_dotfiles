#!/usr/bin/env python3
"""pokemon コマンドの短縮版 (図鑑情報+種族値を表示)
Usage:
  poke 150         # ミュウツー
  poke -n gengar   # ゲンガー
  poke             # ランダム
  poke --clear     # 背景をクリア (Ghostty/cmux)

Supports iTerm2 (AppleScript) and Ghostty/cmux (Kitty graphics protocol).
Backend is auto-detected via $TERM_PROGRAM.
"""
import base64
import io
import os
import subprocess
import sys

from pokemonterminal.database import Database
from pokeutil import load_data, pokemon_oneliner

CURRENT_POKEMON_PATH = os.path.expanduser("~/.cache/poke-current")
KITTY_OPACITY = 60  # 0-255, lower = more transparent


# ── Pokemon lookup ────────────────────────────────────────

def find_chosen_pokemon(args):
    """dry-run で選ばれるポケモンを特定し、DB上のオブジェクトを返す"""
    result = subprocess.run(
        ["pokemon"] + args + ["-dr"],
        capture_output=True, text=True,
    )
    output = result.stdout + result.stderr
    chosen_name = None
    for line in output.splitlines():
        if "Chose" in line:
            chosen_name = line.split("Chose")[-1].strip()
            break
    if not chosen_name:
        return None
    db = Database()
    for p in db.get_all():
        if p.get_name().lower() == chosen_name.lower():
            return p
    return None


def save_current_pokemon(en_name: str) -> None:
    """Save current Pokemon name for TRAPWINCH resize redraw."""
    os.makedirs(os.path.dirname(CURRENT_POKEMON_PATH), exist_ok=True)
    with open(CURRENT_POKEMON_PATH, "w") as f:
        f.write(en_name)


# ── iTerm2 backend ────────────────────────────────────────

def set_iterm_background(pid: str, en_name: str) -> None:
    """Set iTerm2 background via pokemon-terminal (AppleScript)."""
    if pid != "---":
        subprocess.run(["pokemon", pid], stdout=subprocess.DEVNULL)
    else:
        subprocess.run(["pokemon", "-n", en_name], stdout=subprocess.DEVNULL)


# ── Kitty graphics protocol backend (for cmux/Ghostty) ───

def _kitty_cmd(stdout, payload: str, data: str = "") -> None:
    """Write a single Kitty graphics escape sequence."""
    stdout.write(f"\033_G{payload};{data}\033\\".encode())


def _prepare_kitty_image(image_path: str) -> bytes:
    """Load image, apply transparency, return PNG bytes."""
    from PIL import Image

    img = Image.open(image_path).convert("RGBA")

    # Apply uniform opacity cap
    r, g, b, a = img.split()
    a = Image.eval(a, lambda x: min(x, KITTY_OPACITY))
    img = Image.merge("RGBA", (r, g, b, a))

    buf = io.BytesIO()
    img.save(buf, format="PNG", optimize=True)
    return buf.getvalue()


def set_kitty_background(image_path: str) -> None:
    """Display image via Kitty graphics protocol (2-phase: transmit + place)."""
    cols, rows = 80, 24
    try:
        size = os.get_terminal_size()
        cols, rows = size.columns, size.lines
    except Exception:
        pass

    png_data = _prepare_kitty_image(image_path)
    stdout = sys.stdout.buffer

    # Delete ALL previous images (works around Ghostty ID bug #6711)
    _kitty_cmd(stdout, "a=d,d=a,q=2")
    stdout.flush()

    # Transmit image data (a=t lowercase = transmit only, no display)
    b64 = base64.b64encode(png_data).decode("ascii")
    chunk_size = 4096
    chunks = [b64[i:i + chunk_size] for i in range(0, len(b64), chunk_size)]

    for idx, chunk in enumerate(chunks):
        is_last = idx == len(chunks) - 1
        m = 0 if is_last else 1
        if idx == 0:
            _kitty_cmd(stdout, f"a=t,f=100,t=d,i=99,q=2,m={m}", chunk)
        else:
            _kitty_cmd(stdout, f"m={m}", chunk)
    stdout.flush()

    # Place image ONCE at home position, behind text
    stdout.write(b"\0337")   # Save cursor
    stdout.write(b"\033[H")  # Move to home
    _kitty_cmd(stdout, f"a=p,i=99,z=-1,C=1,c={cols},r={rows},q=2")
    stdout.write(b"\0338")   # Restore cursor
    stdout.flush()


def clear_kitty_background() -> None:
    """Remove all Kitty graphics images."""
    _kitty_cmd(sys.stdout.buffer, "a=d,d=a,q=2")
    sys.stdout.buffer.flush()
    # Also clear saved Pokemon
    try:
        os.remove(CURRENT_POKEMON_PATH)
    except FileNotFoundError:
        pass


# ── Main ──────────────────────────────────────────────────

def main():
    args = sys.argv[1:]
    term = os.environ.get("TERM_PROGRAM", "")

    if "--clear" in args:
        if term == "ghostty":
            clear_kitty_background()
        return

    chosen = find_chosen_pokemon(args)
    if not chosen:
        subprocess.run(["pokemon"] + args)
        return

    pid = chosen.get_id()
    en_name = chosen.get_name()

    if term == "ghostty":
        set_kitty_background(chosen.get_path())
        save_current_pokemon(en_name)
    else:
        set_iterm_background(pid, en_name)

    data = load_data()
    t1 = chosen.get_pkmn_type()
    t2 = chosen.get_pkmn_type_secondary()
    print(pokemon_oneliner(pid, en_name, data, t1, t2))


if __name__ == "__main__":
    main()

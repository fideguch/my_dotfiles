{
  "model": "claude-fable-5[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx block-no-verify@1.1.2"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/hooks/pm-pipeline-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/hooks/forge-ace-dispatch-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/hooks/gatekeeper-pre-edit-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hooks/bochi-s3-pull-on-read.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Agent|Task|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/fumito_ideguchi/token-guard/hooks/tg-record.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hooks/bochi-s3-pull.sh",
            "timeout": 30,
            "async": true
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hooks/skill-health-check.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/my_dotfiles/pokemon-terminal/claude/session-start.sh",
            "timeout": 3,
            "async": true
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hooks/pokechamp-ensure-schedule.sh",
            "timeout": 10,
            "async": true
          }
        ]
      },
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "[ -d \"${CLAUDE_PROJECT_DIR:-.}/.fable\" ] || exit 0; cat \"$HOME/.claude/skills/fable-for-opus/hooks/fable-core-card.md\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/fumito_ideguchi/token-guard/hooks/tg-session-start.mjs",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hooks/bochi-feedback-capture.sh",
            "timeout": 10,
            "async": true
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hooks/bochi-s3-push.sh",
            "timeout": 30,
            "async": true
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "[ -d \"${CLAUDE_PROJECT_DIR:-.}/.fable\" ] || exit 0; bash \"$HOME/.claude/skills/fable-for-opus/hooks/fable-post-edit.sh\"",
            "timeout": 60,
            "statusMessage": "fable post-edit check"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hooks/claude-stop-notify.sh",
            "timeout": 10,
            "async": true
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/hooks/forge-ace-session-complete.js",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/hooks/gatekeeper-stop-check.js",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/hooks/gatekeeper-session-rotate.js",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/skills/fable-for-opus/hooks/fable-stop-gate.sh\"",
            "timeout": 10,
            "statusMessage": "fable stop gate"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/fumito_ideguchi/token-guard/hooks/tg-stop-audit.mjs",
            "timeout": 15,
            "statusMessage": "token-guard audit"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/fumito_ideguchi/token-guard/hooks/tg-prompt-gate.mjs",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/my_dotfiles/pokemon-terminal/claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "discord@claude-plugins-official": false,
    "swift-lsp@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true
}

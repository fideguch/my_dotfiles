# Build artifacts (regenerated by scripts/setup.sh / build_calc.sh)
bin/pokechamp-calc

# Showdown data (regenerated by scripts/extract_data.ts, ~4MB total)
# Comment out next 2 lines if you want to commit data for offline-first use.
data/*.json
data/*.json.gz
data/stats/*.json
!data/VERSION.json

# Runtime cache (per-machine, never tracked)
cache/

# Local gatekeeper/forge_ace session data
.gatekeeper/
.forge-ace/

# Bun / npm
scripts/node_modules/
scripts/bun.lock
scripts/package-lock.json
*.log

# OS
.DS_Store
